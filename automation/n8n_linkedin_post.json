            },
            {
              "name": "message",
              "value": "=✅ LinkedIn Post erfolgreich!\n💼 Post ID: {{ $json.post_id }}\n🔗 {{ $json.post_url }}"
            }
          ]
        },
        "options": {}
      },
      "id": "li-notify",
