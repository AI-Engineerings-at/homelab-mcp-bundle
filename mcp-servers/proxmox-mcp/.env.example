# Proxmox VE MCP Server — Environment Variables
# Copy to .env and fill in your values

# Proxmox VE host URL (include port 8006, use https)
PVE_HOST=https://your-proxmox-host:8006

# PVE user in the format user@realm (e.g. root@pam or apiuser@pve)
PVE_USER=root@pam

# Password for the PVE user
PVE_PASSWORD=your_password_here

# Set to true if you have a valid SSL certificate, false to skip verification
PVE_VERIFY_SSL=false
