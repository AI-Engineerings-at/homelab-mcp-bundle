# n8n MCP Server — Environment Variables
# Copy to .env and fill in your values

# n8n instance URL (no trailing slash)
N8N_BASE_URL=http://10.40.10.80:5678

# n8n API Key (Settings → API → Create API Key)
N8N_API_KEY=your_n8n_api_key_here

# Optional: webhook base URL if different from N8N_BASE_URL
# N8N_WEBHOOK_URL=http://10.40.10.80:5678
