# Portainer MCP Server — Environment Variables
# Copy to .env and fill in your values

# Portainer instance URL (no trailing slash)
PORTAINER_URL=http://localhost:9000

# Auth option 1 (recommended): API Access Token
# Generate in Portainer → Account (top right) → Access Tokens → Add access token
PORTAINER_API_TOKEN=your_portainer_api_token_here

# Auth option 2: Username + Password (used only if PORTAINER_API_TOKEN is not set)
# PORTAINER_USER=admin
# PORTAINER_PASSWORD=your_password_here

# Portainer Endpoint ID (usually 1 for the primary Docker/Swarm endpoint)
# Leave at 1 unless you have a custom multi-endpoint setup
PORTAINER_ENDPOINT_ID=1
