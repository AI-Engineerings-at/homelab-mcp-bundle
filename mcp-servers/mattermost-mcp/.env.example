# Mattermost MCP Server — Environment Variables
# Copy to .env and fill in your values

# Mattermost instance URL (no trailing slash)
MM_BASE_URL=https://your-mattermost.example.com

# Personal Access Token (Settings → Security → Personal Access Tokens)
# Needs: read_channel, post, read_users permissions
MM_TOKEN=your_personal_access_token_here

# Team ID (visible in Team Settings URL or via API: GET /api/v4/teams)
MM_TEAM_ID=your_team_id_here
