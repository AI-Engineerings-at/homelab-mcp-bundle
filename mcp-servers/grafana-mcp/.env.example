# Grafana MCP Server — Environment Variables

# Grafana instance URL
GRAFANA_URL=http://localhost:3000

# Authentication — use API token (preferred) OR username/password
# Option 1: Service Account Token (recommended)
GRAFANA_TOKEN=glsa_your_service_account_token_here

# Option 2: Username + Password (Basic Auth)
GRAFANA_USER=admin
GRAFANA_PASSWORD=your_password_here
