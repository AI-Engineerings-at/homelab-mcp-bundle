{
  "mcpServers": {
    "n8n": {
      "command": "python3",
      "args": ["/path/to/homelab-mcp-bundle/n8n-mcp/server.py"],
      "env": {
        "N8N_BASE_URL": "http://your-n8n-host:5678/api/v1",
        "N8N_API_KEY": "your-api-key",
        "N8N_WEBHOOK_BASE": "http://your-n8n-host:5678/webhook"
      }
    }
  }
}
